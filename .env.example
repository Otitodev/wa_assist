# Database
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Server
API_PORT="8000"
LOG_LEVEL="info"

# Security
EVOLUTION_WEBHOOK_SHARED_SECRET="change-me"
CRON_SECRET="change-me-cron-secret"

# Auto-resume configuration
# Hours of inactivity before auto-resuming paused sessions
RESUME_AFTER_HOURS="2"

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS="http://localhost:3000,https://your-frontend-domain.vercel.app"

# LLM Provider Configuration
# Provider options: anthropic, openai
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
LLM_MAX_TOKENS="1024"
LLM_TIMEOUT="10"

# Default system prompt (optional - can be overridden per tenant)
DEFAULT_SYSTEM_PROMPT="You are a helpful WhatsApp assistant. Respond professionally and concisely to customer inquiries."

# n8n Integration (optional - for workflow orchestration)
# Set N8N_ENABLED=true to delegate AI workflows to n8n instead of running them in FastAPI
N8N_ENABLED="false"
N8N_WEBHOOK_URL="http://localhost:5678/webhook"
N8N_API_KEY="your-n8n-api-key"

# WebSocket Configuration (alternative to webhooks)
# Set WEBSOCKET_ENABLED=true to use Socket.IO connection instead of webhooks
# Note: Evolution API must have WEBSOCKET_ENABLED=true on their end
WEBSOCKET_ENABLED="false"
# Mode: "global" receives events from all instances, "instance" requires per-instance connection
WEBSOCKET_MODE="global"
# Evolution API server URL (required for WhatsApp QR code connection)
EVOLUTION_SERVER_URL="https://your-evolution-api.com"
# Global API key for Evolution API authentication
EVOLUTION_API_KEY="your-evolution-api-key"
# Webhook URL base for Evolution API to call back
# This should be your Whaply backend's public URL
WEBHOOK_BASE_URL="https://your-whaply-backend.whaply.co"

# Message Delay Configuration (to avoid WhatsApp bans)
# Adds human-like random delays before sending messages
MESSAGE_DELAY_ENABLED="true"
MESSAGE_DELAY_MIN_MS="1000"   # Minimum delay in milliseconds (1 second)
MESSAGE_DELAY_MAX_MS="3000"   # Maximum delay in milliseconds (3 seconds)

# Typing Indicator Configuration
# Shows "typing..." while generating AI reply
TYPING_INDICATOR_ENABLED="true"

# Media Processing (images via Claude Vision, audio via OpenAI Whisper)
# Set to false to disable media processing and send fallback replies instead
MEDIA_PROCESSING_ENABLED="true"

# Cloudflare R2 Storage (required for media processing)
# Create a bucket at dash.cloudflare.com → R2, then generate an API token
CF_R2_ACCOUNT_ID="your-cloudflare-account-id"
CF_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CF_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CF_R2_BUCKET_NAME="whaply-media"
# Public URL for your R2 bucket (enable public access or use a custom domain)
CF_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# Conversation Context
# Number of previous messages to include in each LLM call for conversation memory
CONTEXT_MESSAGES="10"

# BetterAuth (required for frontend session validation)
BETTER_AUTH_SECRET="generate-a-long-random-secret-here"

# Billing — Paystack (Nigerian/African customers)
# Sign up at paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY="sk_live_..."
PAYSTACK_PUBLIC_KEY="pk_live_..."

# Billing — Lemonsqueezy (International customers, handles VAT/GST globally)
# Sign up at lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY="..."
LEMONSQUEEZY_WEBHOOK_SECRET="..."
LEMONSQUEEZY_STORE_ID="..."
